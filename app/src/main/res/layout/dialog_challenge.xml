<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Cuerpo principal del diálogo -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_dialog_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="280dp"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/dialog_background"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingTop="80dp"
        android:paddingEnd="24dp"
        android:paddingBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_challenge_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="¡Reto Aleatorio!"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Círculo con la imagen del Pokémon -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:background="@drawable/pokemon_circle"
        android:elevation="6dp"
        app:layout_constraintBottom_toTopOf="@+id/cl_dialog_body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cl_dialog_body">

        <ImageView
            android:id="@+id/iv_pokemon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:contentDescription="Imagen Pokémon" />

    </FrameLayout>

    <!-- Botón Cerrar: Rectangular con esquinas ligeramente redondeadas -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_dialog"
        android:layout_width="160dp"
        android:layout_height="56dp"
        android:backgroundTint="@color/orange_main"
        android:text="Cerrar"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        app:cornerRadius="8dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/cl_dialog_body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_dialog_body" />

</androidx.constraintlayout.widget.ConstraintLayout>