<?xml version="1.0" encoding="utf-8"?>
<!-- Declaración inicial del archivo XML -->

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- layer-list permite colocar la botella dentro del ícono launcher -->

    <item
        android:width="24dp"
        android:height="59dp"
        android:gravity="center"
        android:drawable="@drawable/ic_bottle" />
    <!-- width="22dp" reduce el ancho para que la botella no se vea gorda -->
    <!-- height="58dp" mantiene una altura suficiente para que se vea como botella -->
    <!-- gravity="center" centra la botella dentro del círculo morado -->
    <!-- drawable="@drawable/ic_bottle" usa la botella verde creada en drawable -->

</layer-list>
    <!-- Cierre del archivo del foreground del ícono -->