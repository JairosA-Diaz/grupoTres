
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="70"
    android:viewportHeight="175">
  <!-- Define un recurso vectorial -->
  <!-- width y height son el tamaño base del drawable -->
  <!-- viewportWidth y viewportHeight definen el sistema interno de coordenadas del dibujo -->

  <group
      android:scaleX="0.27"
      android:scaleY="0.63"
      android:translateX="26"
      android:translateY="31">
    <!-- group agrupa todas las partes de la botella -->
    <!-- scaleX aumenta el ancho de toda la botella -->
    <!-- scaleY aumenta el alto de toda la botella -->
    <!-- translateX mueve la botella hacia izquierda o derecha -->
    <!-- translateY mueve la botella hacia arriba o abajo -->
    <!-- En este caso aumentamos el tamaño y la reubicamos para que siga centrada -->

    <path
        android:pathData="M15,167L55,167C65,167 60,157 60,147L60,87L50,47L50,17L20,17L20,47L10,87L10,147C10,157 5,167 15,167Z"
        android:strokeWidth="1"
        android:strokeColor="#0d3b21">
      <!-- Dibuja el cuerpo principal de la botella -->
      <!-- strokeWidth define el grosor del borde -->
      <!-- strokeColor define el color del borde -->

      <aapt:attr name="android:fillColor">
        <!-- fillColor se define con un gradiente -->

        <gradient
            android:startX="8.75"
            android:startY="17"
            android:endX="61.25"
            android:endY="17"
            android:type="linear">
          <!-- Gradiente lineal de izquierda a derecha -->

          <item android:offset="0" android:color="#FF145A32"/>
          <!-- Color inicial del gradiente -->

          <item android:offset="0.5" android:color="#FF2ECC71"/>
          <!-- Color del centro del gradiente -->

          <item android:offset="1" android:color="#FF1E8449"/>
          <!-- Color final del gradiente -->
        </gradient>
      </aapt:attr>
    </path>

    <path
        android:pathData="M20,12L50,12A2,2 0,0 1,52 14L52,18A2,2 0,0 1,50 20L20,20A2,2 0,0 1,18 18L18,14A2,2 0,0 1,20 12z"
        android:strokeWidth="1"
        android:fillColor="#2ecc71"
        android:strokeColor="#0d3b21"/>
    <!-- Dibuja la tapa o borde superior de la botella -->

    <path
        android:pathData="M35,122m-18,0a18,18 0,1 1,36 0a18,18 0,1 1,-36 0"
        android:strokeWidth="1"
        android:fillColor="#d4af37"
        android:strokeColor="#997a1d"/>
    <!-- Dibuja el círculo principal de la etiqueta -->

    <path
        android:pathData="M35,122m-14,0a14,14 0,1 1,28 0a14,14 0,1 1,-28 0"
        android:strokeWidth="0.5"
        android:fillColor="#00000000"
        android:strokeColor="#997a1d"/>
    <!-- Dibuja el aro interno de la etiqueta -->

    <path
        android:pathData="M22,52L23,52A2,2 0,0 1,25 54L25,150A2,2 0,0 1,23 152L22,152A2,2 0,0 1,20 150L20,54A2,2 0,0 1,22 52z"
        android:strokeAlpha="0.3"
        android:fillColor="#ffffff"
        android:fillAlpha="0.3"/>
    <!-- Dibuja un brillo vertical en la botella -->
    <!-- strokeAlpha y fillAlpha controlan la transparencia -->

    <path
        android:pathData="M46,52L47,52A1,1 0,0 1,48 53L48,111A1,1 0,0 1,47 112L46,112A1,1 0,0 1,45 111L45,53A1,1 0,0 1,46 52z"
        android:strokeAlpha="0.2"
        android:fillColor="#ffffff"
        android:fillAlpha="0.2"/>
    <!-- Dibuja un segundo brillo más delgado -->
  </group>
</vector>
